datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Seat {
  id          String    @id @default(cuid())
  section     String    // "LEFT", "MIDDLE", "RIGHT"
  row         Int
  number      Int
  status      String    @default("AVAILABLE") // "AVAILABLE", "LOCKED", "BOOKED"
  lockedUntil DateTime?
  userEmail   String?   // Email of the person locking/booking
}

model Booking {
  id        String   @id @default(cuid())
  userEmail String
  seats     String   // comma-separated Seat IDs
  status    String   @default("CONFIRMED")
  createdAt DateTime @default(now())
}
