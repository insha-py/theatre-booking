datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

model Seat {
  id          String    @id @default(cuid())
  showDate    String    // "2026-04-25", "2026-04-26"
  section     String    // "LEFT", "MIDDLE", "RIGHT"
  row         Int
  number      Int
  status      String    @default("AVAILABLE") // "AVAILABLE", "LOCKED", "BOOKED"
  lockedUntil DateTime?
  userEmail   String?   // Email of the person locking/booking
}

model Booking {
  id        String   @id @default(cuid())
  showDate  String   // "2026-04-25", "2026-04-26"
  userEmail String
  seats     String   // comma-separated Seat IDs
  status    String   @default("CONFIRMED")
  createdAt DateTime @default(now())
}
